# Chỉ chứa secrets / API keys. Mọi cấu hình khác: xem config.yaml
# (vẫn có thể override bằng biến môi trường cũ, ví dụ OLLAMA_URL, nếu cần)

PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# ElevenLabs (when tts.elevenlabs.enabled: true in config.yaml)
ELEVENLABS_API_KEY=

# YouTube (youtube.upload: true): register redirect http://127.0.0.1:<port>/ in Google Cloud if needed
# YOUTUBE_OAUTH_PORT=8080

# Optional: absolute paths if not on PATH (MoviePy's imageio_ffmpeg provides ffmpeg in venv)
# FFMPEG_BINARY=
# FFPROBE_BINARY=
